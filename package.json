{
  "name": "teal",
  "author": "Edward Shturman",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "description": "A minimalist, paginated Twitter timeline viewer",
  "repository": {
    "type": "git",
    "url": "https://github.com/edwardshturman/teal"
  },
  "private": true,
  "scripts": {
    "predev": "bun install",
    "dev": "next dev --turbopack",
    "lint": "eslint .",
    "format:check": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown",
    "prebuild": "bun run lint && bun run format:check",
    "build": "next build --turbopack",
    "start": "next start"
  },
  "lint-staged": {
    "**/*": [
      "bun run lint",
      "bun run format:write"
    ]
  },
  "dependencies": {
    "@xdevplatform/xdk": "0.4.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "1.3.10",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "husky": "9.1.7",
    "lint-staged": "16.1.5",
    "prettier": "3.6.2",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.x"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
